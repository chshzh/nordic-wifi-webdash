config APP_MODE_SELECTOR
	bool "Enable Wi-Fi mode selector"
	default y
	select SETTINGS
	select FLASH
	select FLASH_MAP
	select FLASH_PAGE_LAYOUT
	help
	  Reads the persisted Wi-Fi mode from NVS on every boot and publishes
	  it on WIFI_MODE_CHAN before the Wi-Fi module starts.  The
	  `wifi_mode [SoftAP|STA|P2P]` shell command can be used at any time to change
	  the active mode; the board reboots automatically to apply the change.

if APP_MODE_SELECTOR

module = MODE_SELECTOR
module-str = mode_selector
source "subsys/logging/Kconfig.template.log_config"

endif # APP_MODE_SELECTOR
